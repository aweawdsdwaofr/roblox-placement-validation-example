-- Server module for placing keycaps.
-- The client can ask to place something, but the server still checks the item,
-- inventory, distance, grid position, and if the spot is already taken.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local HttpService = game:GetService("HttpService")

local PlacementService = {}

local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local PlaceItemRemote = Remotes:WaitForChild("PlaceItem")

local ItemFolder = ReplicatedStorage:WaitForChild("PlaceableItems")

local PlacedItems = Workspace:FindFirstChild("PlacedItems")
if not PlacedItems then
	PlacedItems = Instance.new("Folder")
	PlacedItems.Name = "PlacedItems"
	PlacedItems.Parent = Workspace
end

local PLACE_DISTANCE = 45
local GRID_SIZE = 2
local PLACE_COOLDOWN = 0.25

local lastRequest = {}
local playerInventories = {}
local placedCounts = {}

-- Item settings are kept on the server so players cannot fake item limits
-- or tell the server to spawn random models from ReplicatedStorage.
local Items = {
	BasicKeycap = {
		ModelName = "BasicKeycap",
		Limit = 50,
	},

	RareKeycap = {
		ModelName = "RareKeycap",
		Limit = 25,
	},

	GoldenKeycap = {
		ModelName = "GoldenKeycap",
		Limit = 10,
	},
}

local function roundToGrid(value)
	return math.floor((value / GRID_SIZE) + 0.5) * GRID_SIZE
end

local function snapPosition(position)
	return Vector3.new(
		roundToGrid(position.X),
		position.Y,
		roundToGrid(position.Z)
	)
end

local function getCharacterRoot(player)
	local character = player.Character
	if not character then
		return nil
	end

	return character:FindFirstChild("HumanoidRootPart")
end

local function getInventory(player)
	local inventory = playerInventories[player]

	if inventory then
		return inventory
	end

	-- This is just starter test data.
	-- In a real game, this would usually come from a DataStore/ProfileService system.
	inventory = {
		BasicKeycap = 5,
		RareKeycap = 2,
		GoldenKeycap = 1,
	}

	playerInventories[player] = inventory

	return inventory
end

local function getPlacedCounts(player)
	local counts = placedCounts[player]

	if counts then
		return counts
	end

	counts = {}

	for itemName in pairs(Items) do
		counts[itemName] = 0
	end

	placedCounts[player] = counts

	return counts
end

local function isValidItem(itemName)
	if typeof(itemName) ~= "string" then
		return false
	end

	if not Items[itemName] then
		return false
	end

	return true
end

local function getItemAmount(player, itemName)
	local inventory = getInventory(player)
	return inventory[itemName] or 0
end

local function ownsItem(player, itemName)
	return getItemAmount(player, itemName) > 0
end

local function removeItem(player, itemName)
	local inventory = getInventory(player)
	local currentAmount = inventory[itemName] or 0

	if currentAmount <= 0 then
		return false
	end

	inventory[itemName] = currentAmount - 1
	return true
end

local function addItem(player, itemName, amount)
	local inventory = getInventory(player)
	local currentAmount = inventory[itemName] or 0

	inventory[itemName] = currentAmount + amount
end

local function isRequestOnCooldown(player)
	local now = os.clock()
	local previous = lastRequest[player]

	if previous and now - previous < PLACE_COOLDOWN then
		return true
	end

	lastRequest[player] = now
	return false
end

local function isValidPosition(position)
	if typeof(position) ~= "Vector3" then
		return false
	end

	if position.X ~= position.X then
		return false
	end

	if position.Y ~= position.Y then
		return false
	end

	if position.Z ~= position.Z then
		return false
	end

	return true
end

-- The client may show its own placement preview, but this distance check
-- still needs to happen on the server so exploiters cannot place across the map.
local function isCloseEnough(player, position)
	local root = getCharacterRoot(player)

	if not root then
		return false, "Character not ready"
	end

	local distance = (root.Position - position).Magnitude

	if distance > PLACE_DISTANCE then
		return false, "Too far away"
	end

	return true
end

local function getTemplate(itemName)
	local itemData = Items[itemName]
	if not itemData then
		return nil
	end

	return ItemFolder:FindFirstChild(itemData.ModelName)
end

local function getTemplateSize(template)
	if template:IsA("Model") then
		local _, size = template:GetBoundingBox()
		return size
	end

	if template:IsA("BasePart") then
		return template.Size
	end

	return Vector3.new(2, 2, 2)
end

local function getPlacementCFrame(itemName, position)
	local template = getTemplate(itemName)

	if not template then
		return nil, nil
	end

	local snapped = snapPosition(position)
	local size = getTemplateSize(template)
	local finalY = snapped.Y + (size.Y / 2)
	local finalPosition = Vector3.new(snapped.X, finalY, snapped.Z)

	return CFrame.new(finalPosition), size
end

local function isAtItemLimit(player, itemName)
	local itemData = Items[itemName]
	local counts = getPlacedCounts(player)
	local currentCount = counts[itemName] or 0

	if currentCount >= itemData.Limit then
		return true
	end

	return false
end

local function addPlacedCount(player, itemName)
	local counts = getPlacedCounts(player)
	counts[itemName] = (counts[itemName] or 0) + 1
end

local function removePlacedCount(player, itemName)
	local counts = getPlacedCounts(player)
	counts[itemName] = math.max((counts[itemName] or 0) - 1, 0)
end

local function getOverlapParams(player)
	local params = OverlapParams.new()
	local ignoreList = {}

	if player.Character then
		table.insert(ignoreList, player.Character)
	end

	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = ignoreList

	return params
end

local function isPlacedObject(instance)
	local current = instance

	while current and current ~= Workspace do
		if current.Parent == PlacedItems then
			return true
		end

		current = current.Parent
	end

	return false
end

-- This checks the space before the item is made.
-- It only blocks other placed items, so floors, baseplates, and plot parts
-- do not instantly make every placement fail.
local function isSpaceFree(player, cframe, size)
	local params = getOverlapParams(player)
	local checkSize = Vector3.new(
		math.max(size.X - 0.1, 0.1),
		math.max(size.Y - 0.1, 0.1),
		math.max(size.Z - 0.1, 0.1)
	)

	local touchingParts = Workspace:GetPartBoundsInBox(cframe, checkSize, params)

	for _, part in ipairs(touchingParts) do
		if part:IsA("BasePart") and isPlacedObject(part) then
			return false
		end
	end

	return true
end

local function anchorObject(object)
	if object:IsA("BasePart") then
		object.Anchored = true
		return
	end

	if object:IsA("Model") then
		for _, part in ipairs(object:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Anchored = true
			end
		end
	end
end

local function moveObject(object, cframe)
	if object:IsA("Model") then
		object:PivotTo(cframe)
		return true
	end

	if object:IsA("BasePart") then
		object.CFrame = cframe
		return true
	end

	return false
end

local function tagObject(object, player, itemName)
	object:SetAttribute("PlacementId", HttpService:GenerateGUID(false))
	object:SetAttribute("OwnerUserId", player.UserId)
	object:SetAttribute("ItemName", itemName)
	object:SetAttribute("PlacedAt", os.time())
end

local function spawnItem(player, itemName, cframe)
	local template = getTemplate(itemName)

	if not template then
		return nil
	end

	local clone = template:Clone()
	local moved = moveObject(clone, cframe)

	if not moved then
		clone:Destroy()
		return nil
	end

	anchorObject(clone)
	tagObject(clone, player, itemName)

	clone.Name = itemName .. "_" .. player.UserId
	clone.Parent = PlacedItems

	return clone
end

local function validateRequest(player, itemName, position)
	if not isValidItem(itemName) then
		return false, "Invalid item"
	end

	if not isValidPosition(position) then
		return false, "Bad position"
	end

	local closeEnough, closeMessage = isCloseEnough(player, position)

	if not closeEnough then
		return false, closeMessage
	end

	if not ownsItem(player, itemName) then
		return false, "You do not own this item"
	end

	if isAtItemLimit(player, itemName) then
		return false, "Item limit reached"
	end

	local template = getTemplate(itemName)

	if not template then
		return false, "Item model missing"
	end

	return true
end

-- Main placement function.
-- The order matters here: validate first, check the space, remove the item,
-- then spawn it. If spawning fails, the item is given back.
function PlacementService.TryPlace(player, itemName, position)
	if isRequestOnCooldown(player) then
		return false, "Slow down"
	end

	local valid, message = validateRequest(player, itemName, position)

	if not valid then
		return false, message
	end

	local cframe, size = getPlacementCFrame(itemName, position)

	if not cframe then
		return false, "Could not place item"
	end

	if not isSpaceFree(player, cframe, size) then
		return false, "Something is already there"
	end

	local removed = removeItem(player, itemName)

	if not removed then
		return false, "Inventory changed"
	end

	local placedObject = spawnItem(player, itemName, cframe)

	if not placedObject then
		addItem(player, itemName, 1)
		return false, "Placement failed"
	end

	addPlacedCount(player, itemName)

	return true, "Placed", placedObject
end

function PlacementService.GetInventory(player)
	local inventory = getInventory(player)
	local copy = {}

	for itemName, amount in pairs(inventory) do
		copy[itemName] = amount
	end

	return copy
end

function PlacementService.GiveItem(player, itemName, amount)
	if not isValidItem(itemName) then
		return false, "Invalid item"
	end

	if typeof(amount) ~= "number" or amount <= 0 then
		return false, "Invalid amount"
	end

	addItem(player, itemName, amount)

	return true, "Item added"
end

function PlacementService.RemovePlacedItem(player, object)
	if not object then
		return false, "Invalid object"
	end

	if object.Parent ~= PlacedItems then
		return false, "Object is not placed"
	end

	if object:GetAttribute("OwnerUserId") ~= player.UserId then
		return false, "You do not own this"
	end

	local itemName = object:GetAttribute("ItemName")

	if not isValidItem(itemName) then
		return false, "Invalid placed item"
	end

	object:Destroy()
	removePlacedCount(player, itemName)
	addItem(player, itemName, 1)

	return true, "Removed"
end

local function sendPlacementResult(player, success, message, itemName, placedObject)
	local data = {
		Success = success,
		Message = message,
		ItemName = itemName,
	}

	if placedObject then
		data.PlacementId = placedObject:GetAttribute("PlacementId")
	end

	PlaceItemRemote:FireClient(player, data)
end

PlaceItemRemote.OnServerEvent:Connect(function(player, itemName, position)
	local success, message, placedObject = PlacementService.TryPlace(player, itemName, position)

	sendPlacementResult(player, success, message, itemName, placedObject)
end)

Players.PlayerRemoving:Connect(function(player)
	lastRequest[player] = nil
	playerInventories[player] = nil
	placedCounts[player] = nil
end)

return PlacementService
